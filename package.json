{
  "name": "agent-observer",
  "version": "1.3.3",
  "description": "Agent Office — 3D observability for AI agents",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "lint": "pnpm run lint:desktop",
    "lint:desktop": "eslint \"src/**/*.{ts,tsx}\" --max-warnings=0",
    "lint:web": "pnpm -C web run lint",
    "typecheck": "tsc -b",
    "package": "electron-vite build && electron-builder --mac --dir",
    "package:dmg": "electron-vite build && electron-builder --mac dmg",
    "test:smoke": "pnpm build && playwright test -c playwright.smoke.config.ts",
    "test:coverage": "pnpm exec c8 --report-dir coverage --reporter=text-summary --reporter=lcov --reporter=json-summary playwright test -c playwright.smoke.config.ts --grep-invert \"desktop smoke flows|managed shell timeout terminates descendant process trees\"",
    "postinstall": "electron-rebuild -f -w node-pty",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "Webrenew",
  "license": "MIT",
  "packageManager": "pnpm@10.12.4",
  "repository": {
    "type": "git",
    "url": "https://github.com/webrenew/agent-observer.git"
  },
  "bugs": {
    "url": "https://github.com/webrenew/agent-observer/issues"
  },
  "homepage": "https://github.com/webrenew/agent-observer#readme",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=10.12.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "node-pty"
    ],
    "overrides": {
      "@hono/node-server": "1.19.10",
      "express-rate-limit": "8.3.0",
      "hono": "4.12.4",
      "tar": ">=7.5.11",
      "minimatch": ">=10.2.3",
      "rollup": ">=4.59.0",
      "flatted": ">=3.4.2",
      "picomatch": ">=4.0.4",
      "path-to-regexp": ">=8.4.0",
      "protobufjs": "7.5.6",
      "lodash": "4.18.1",
      "vite": "6.4.2",
      "@xmldom/xmldom": "0.8.13",
      "fast-uri": "3.1.2",
      "tmp": "0.2.6",
      "esbuild": ">=0.28.1"
    }
  },
  "dependencies": {
    "@memories.sh/cli": "^0.7.9",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@react-three/drei": "^10.0.0",
    "@react-three/fiber": "^9.6.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "electron-updater": "^6.8.3",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "three": "^0.182.0",
    "typescript-language-server": "^5.3.0",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-langservers-extracted": "^4.10.0",
    "vscode-languageserver-protocol": "^3.17.5",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.1.0",
    "@types/three": "^0.182.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "c8": "^10.1.3",
    "electron": "^40.10.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "6.4.2"
  },
  "build": {
    "appId": "com.webrenew.agent-observer",
    "productName": "Agent Observer",
    "artifactName": "${name}-${version}-${arch}.${ext}",
    "afterSign": "scripts/notarize.cjs",
    "mac": {
      "identity": "Webrenew LLC (6M8Q4L7AB2)",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "category": "public.app-category.developer-tools",
      "icon": "resources/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "dir",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Agent Observer",
      "icon": "resources/icon.icns",
      "background": "resources/dmg-background.png",
      "iconSize": 132,
      "iconTextSize": 16,
      "contents": [
        {
          "x": 230,
          "y": 290
        },
        {
          "x": 690,
          "y": 290,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 920,
        "height": 560
      }
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/node-pty",
        "to": "node_modules/node-pty",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/@memories.sh/cli",
        "to": "node_modules/@memories.sh/cli",
        "filter": [
          "dist/**/*",
          "package.json"
        ]
      }
    ]
  }
}
